# ── Base de données ──────────────────────────────────────────
# Chaîne de connexion PostgreSQL (Neon, Supabase, Vercel Postgres, local…)
# Runtime applicatif : utilise l'URL *poolée* (Neon : hôte avec "-pooler").
DATABASE_URL="postgresql://user:password@localhost:5432/drivecord"
# Migrations Prisma : URL *directe* (non poolée). Sur Neon, hôte SANS "-pooler".
# En PostgreSQL local classique, identique à DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/drivecord"

# ── Auth.js / NextAuth v5 ────────────────────────────────────
# Génère une valeur avec :  npx auth secret
AUTH_SECRET=""
# URL de base — souvent inutile sur Vercel, utile en local
# AUTH_URL="http://localhost:3000"

# Clé de chiffrement serveur (AES-256-GCM) — 64 caractères hexadécimaux (32 octets).
# Génère :  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# ── OAuth (optionnel) ────────────────────────────────────────
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# ── Email / Resend ───────────────────────────────────────────
# Clé API Resend (vérification email, codes de connexion, 2FA).
# Convention Auth.js : la variable se nomme AUTH_RESEND_KEY.
AUTH_RESEND_KEY=""
# Expéditeur des emails (domaine vérifié sur Resend).
EMAIL_FROM="Drivecord <no-reply@drivecord.app>"

# ── WebAuthn / Passkeys (optionnel — fallback automatique) ────
# Si non définis, le serveur déduit ces valeurs de l'origine de la requête en
# production, et retombe sur "localhost" en développement.
# RP_ID  = domaine (Relying Party ID) : "drivecord.vercel.app" en prod, "localhost" en dev.
RP_ID=""
# RP_NAME = nom affiché lors de l'enregistrement d'un passkey.
RP_NAME="Drivecord"
# WEBAUTHN_ORIGIN = origine complète attendue : "https://drivecord.vercel.app" en prod.
WEBAUTHN_ORIGIN=""

# ── 2FA / TOTP (optionnel) ───────────────────────────────────
# Émetteur affiché dans l'app d'authentification (Google Authenticator, Authy…).
TOTP_ISSUER="Drivecord"

# ── Admin (optionnel) ────────────────────────────────────────
# E-mail qui obtient l'accès à l'espace admin
ADMIN_EMAIL=""
