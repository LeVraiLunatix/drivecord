# ── Base de données ──────────────────────────────────────────
# Chaîne de connexion PostgreSQL (Neon, Supabase, Vercel Postgres, local…)
DATABASE_URL="postgresql://user:password@localhost:5432/drivecord"

# ── Auth.js / NextAuth v5 ────────────────────────────────────
# Génère une valeur avec :  npx auth secret
AUTH_SECRET=""
# URL de base — souvent inutile sur Vercel, utile en local
# AUTH_URL="http://localhost:3000"

# Clé de chiffrement serveur pour les données sensibles (32+ caractères aléatoires)
ENCRYPTION_KEY=""

# ── OAuth (optionnel) ────────────────────────────────────────
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# ── Admin (optionnel) ────────────────────────────────────────
# E-mail qui obtient l'accès à l'espace admin
ADMIN_EMAIL=""
