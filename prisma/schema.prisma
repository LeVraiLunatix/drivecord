// Auth.js v5 + Discloud schema
// Generator: Prisma 7 (output to src/generated/prisma)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Auth.js required tables ───────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  /// bcrypt hash — null for OAuth-only accounts
  password      String?
  /// bcrypt hash of the vault PIN — null until the user sets one
  vaultPin      String?
  /// base64 PBKDF2 salt used to derive the vault encryption key from the PIN
  vaultSalt     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  /// Dernière connexion réussie (sert à la règle de re-vérification email 24 h).
  lastLoginAt      DateTime?
  /// 2FA activée (au moins une méthode active : TOTP et/ou email).
  twoFactorEnabled Boolean   @default(false)
  /// Méthode 2FA PRÉFÉRÉE (présentée en premier au login) : "totp" | "email" | null.
  twoFactorMethod  String?
  /// 2FA par email activée (le statut TOTP est porté par TotpSecret.enabled).
  emailOtpEnabled  Boolean   @default(false)
  /// 2FA par approbation depuis un autre appareil de confiance.
  deviceApprovalEnabled Boolean @default(false)

  /// Palier Patreon débloqué : 0 = aucun, 1 = Gold, 2 = Premium, 3 = VIP.
  /// Calculé depuis l'API Patreon (montant engagé) ; les features premium se
  /// gatent avec `patreonTier >= niveau_requis` (héritage automatique).
  patreonTier     Int       @default(0)
  /// Dernière synchro du palier avec Patreon (null tant que Patreon non lié).
  patreonSyncedAt DateTime?

  accounts       Account[]
  sessions       Session[]
  webhooks       Webhook[]
  authenticators Authenticator[]
  emailTokens    EmailVerificationToken[]
  totpSecret     TotpSecret?
  recoveryCodes  RecoveryCode[]
  trustedDevices TrustedDevice[]
  loginRequests  LoginRequest[]
  pushTokens     PushToken[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── Discloud models ───────────────────────────────────────────────────────────

/// One per Discord webhook, linked to a user account.
/// The URL is stored AES-256-GCM encrypted (server-side key).
model Webhook {
  id           String   @id @default(cuid())
  userId       String
  /// SHA-256 of the webhook URL — same as the local Drive.id
  driveId      String
  /// AES-256-GCM encrypted webhook URL (base64)
  encryptedUrl String
  /// AES-256-GCM encrypted per-drive file key (base64) — null until set.
  /// Encrypts all of this drive's regular (non-vault) file uploads.
  encKey       String?
  name         String
  channelId    String
  guildId      String?
  createdAt    DateTime @default(now())
  lastOpenedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  files   DriveFile[]
  folders DriveFolder[]
  shares  Share[]

  @@unique([userId, driveId])
}

/// A public share link for a single file.
model Share {
  token        String    @id
  webhookId    String
  fileId       String
  /// bcrypt hash of the optional access password (null = no password)
  passwordHash String?
  expiresAt    DateTime?
  downloads    Int       @default(0)
  createdAt    DateTime  @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([fileId])
}

// ── Drive content (files + folders) ──────────────────────────────────────────

/// A file uploaded via a webhook. `chunks` is a JSON array of ChunkRef objects.
model DriveFile {
  id        String    @id
  webhookId String
  driveId   String
  parentId  String    @default("")
  filename  String
  /// Total byte size (sum of chunks). Int covers up to ~2 GB.
  size      Int
  mimeType  String    @default("")
  chunkSize Int
  /// ChunkRef[] — ordered list of Discord message references.
  chunks    Json
  tags      String[]
  favorite  Boolean   @default(false)
  locked    Boolean   @default(false)
  /// base64 AES-GCM IV — present iff the file content is E2EE encrypted
  encIv     String?
  trashed   Boolean   @default(false)
  trashedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, parentId])
  @@index([webhookId, trashed])
  @@index([webhookId, favorite])
}

/// A virtual folder (Discord has no notion of folders).
model DriveFolder {
  id        String    @id
  webhookId String
  driveId   String
  parentId  String    @default("")
  name      String
  color     String?
  trashed   Boolean   @default(false)
  trashedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, parentId])
  @@index([webhookId, trashed])
}

// ── Authentification avancée ──────────────────────────────────────────────────

/// Passkey WebAuthn (clé d'accès) enregistrée pour un utilisateur.
model Authenticator {
  id           String    @id @default(cuid())
  userId       String
  /// base64url de l'identifiant de credential (unique).
  credentialId String    @unique
  /// Clé publique COSE (bytea).
  publicKey    Bytes
  /// Compteur de signature anti-rejeu.
  counter      BigInt    @default(0)
  /// Transports annoncés ("usb", "ble", "nfc", "internal", "hybrid"…).
  transports   String[]
  /// "singleDevice" | "multiDevice".
  deviceType   String?
  backedUp     Boolean   @default(false)
  /// Libellé éditable par l'utilisateur.
  name         String
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Code de vérification email à usage unique (6 chiffres, hashé SHA-256).
model EmailVerificationToken {
  id         String    @id @default(cuid())
  /// Null possible pour un flux pré-compte ; rempli dès que l'user existe.
  userId     String?
  email      String
  codeHash   String
  /// "signup" | "login_24h" | "2fa" | "email_change".
  purpose    String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose])
  @@index([userId])
}

/// Secret TOTP (app d'authentification), chiffré au repos via ENCRYPTION_KEY.
model TotpSecret {
  id              String    @id @default(cuid())
  userId          String    @unique
  /// Secret base32 chiffré (AES-256-GCM, même format que les webhooks).
  secretEncrypted String
  enabled         Boolean   @default(false)
  confirmedAt     DateTime?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Code de récupération 2FA (usage unique, hashé). Lot de 10 à l'activation.
model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Appareil de confiance (identifié par un cookie persistant `deviceId`).
model TrustedDevice {
  id          String   @id @default(cuid())
  userId      String
  /// Identifiant d'appareil stocké côté client (cookie httpOnly persistant).
  deviceId    String
  deviceLabel String
  userAgent   String?
  ip          String?
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}

/// Demande d'approbation de connexion depuis un nouvel appareil (style Epic Games).
model LoginRequest {
  id                    String   @id @default(cuid())
  userId                String
  requestingDeviceLabel String
  requestingIp          String?
  requestingLocation    String?
  /// Code court (4-6 chiffres) affiché sur les deux appareils (anti-phishing).
  shortCode             String
  /// Secret aléatoire connu du seul nouvel appareil, pour poll + claim de session.
  pollToken             String   @unique
  /// "pending" | "approved" | "denied" | "expired".
  status                String   @default("pending")
  expiresAt             DateTime
  approvedByDeviceId    String?
  createdAt             DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

/// Compteur de rate-limiting (fenêtre fixe), backend PostgreSQL.
model RateLimit {
  id        String   @id @default(cuid())
  /// Clé logique "<action>:<dimension>:<valeur>" (ex. "emailcode:ip:1.2.3.4").
  key       String   @unique
  count     Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

/// Jeton de notification push (APNs) d'un appareil natif, pour prévenir les
/// appareils de confiance d'une demande de connexion cross-device.
model PushToken {
  id        String   @id @default(cuid())
  userId    String
  /// Jeton APNs de l'appareil (unique — se réassigne au compte connecté).
  token     String   @unique
  platform  String   @default("ios")
  /// Cookie deviceId de l'appareil de confiance correspondant, si connu.
  deviceId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Annonce affichée en popup sur le site (configurée par l'admin).
model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  /// Annonce marquée « importante » → style accentué dans la popup.
  important Boolean  @default(false)
  /// Date jusqu'à laquelle la popup s'affiche aux visiteurs.
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}
