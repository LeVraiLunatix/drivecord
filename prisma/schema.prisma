// Auth.js v5 + Discloud schema
// Generator: Prisma 7 (output to src/generated/prisma)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Auth.js required tables ───────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  /// bcrypt hash — null for OAuth-only accounts
  password      String?
  /// bcrypt hash of the vault PIN — null until the user sets one
  vaultPin      String?
  /// base64 PBKDF2 salt used to derive the vault encryption key from the PIN
  vaultSalt     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  webhooks Webhook[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── Discloud models ───────────────────────────────────────────────────────────

/// One per Discord webhook, linked to a user account.
/// The URL is stored AES-256-GCM encrypted (server-side key).
model Webhook {
  id           String   @id @default(cuid())
  userId       String
  /// SHA-256 of the webhook URL — same as the local Drive.id
  driveId      String
  /// AES-256-GCM encrypted webhook URL (base64)
  encryptedUrl String
  name         String
  channelId    String
  guildId      String?
  createdAt    DateTime @default(now())
  lastOpenedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  files   DriveFile[]
  folders DriveFolder[]
  shares  Share[]

  @@unique([userId, driveId])
}

/// A public share link for a single file.
model Share {
  token        String    @id
  webhookId    String
  fileId       String
  /// bcrypt hash of the optional access password (null = no password)
  passwordHash String?
  expiresAt    DateTime?
  downloads    Int       @default(0)
  createdAt    DateTime  @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([fileId])
}

// ── Drive content (files + folders) ──────────────────────────────────────────

/// A file uploaded via a webhook. `chunks` is a JSON array of ChunkRef objects.
model DriveFile {
  id        String    @id
  webhookId String
  driveId   String
  parentId  String    @default("")
  filename  String
  /// Total byte size (sum of chunks). Int covers up to ~2 GB.
  size      Int
  mimeType  String    @default("")
  chunkSize Int
  /// ChunkRef[] — ordered list of Discord message references.
  chunks    Json
  tags      String[]
  favorite  Boolean   @default(false)
  locked    Boolean   @default(false)
  /// base64 AES-GCM IV — present iff the file content is E2EE encrypted
  encIv     String?
  trashed   Boolean   @default(false)
  trashedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, parentId])
  @@index([webhookId, trashed])
  @@index([webhookId, favorite])
}

/// A virtual folder (Discord has no notion of folders).
model DriveFolder {
  id        String    @id
  webhookId String
  driveId   String
  parentId  String    @default("")
  name      String
  color     String?
  trashed   Boolean   @default(false)
  trashedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, parentId])
  @@index([webhookId, trashed])
}
